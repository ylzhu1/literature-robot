# Copy this file to .env and fill in your private credentials.
# Never commit .env to GitHub.

# Optional email settings. The current default workflow uses Feishu only.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_smtp_authorization_code
SMTP_USE_SSL=true
SMTP_USE_TLS=false

# OpenAI-compatible LLM endpoint.
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://your-api-provider.example.com/v1
LLM_MODEL=gpt-4o-mini

# Feishu custom bot webhook.
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id
